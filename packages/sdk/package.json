{
  "name": "@agentmcp/sdk",
  "version": "0.1.0",
  "description": "Wrap any agent as a payable MCP server with 0G + ENS + KeeperHub",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sentinel": {
      "import": "./dist/sentinel/keeper.js",
      "types": "./dist/sentinel/keeper.d.ts"
    },
    "./knowledge": {
      "import": "./dist/knowledge/sharing.js",
      "types": "./dist/knowledge/sharing.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "@0glabs/0g-serving-broker": "^0.6.5",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0",
    "@uniswap/v3-sdk": "^3.13.0",
    "@uniswap/smart-order-router": "^3.44.0",
    "@uniswap/sdk-core": "^5.3.0",
    "graphql-request": "^7.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
