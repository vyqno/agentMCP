# === KeeperHub / x402 Payment ===
SKIP_PAYMENT=true                     # Set to false in production to enforce x402
RECIPIENT_ADDRESS=0xYOUR_WALLET_HERE  # Address that receives per-call fees
CHAIN_ID=11155111                     # 11155111=Sepolia, 8453=Base, 84532=Base Sepolia
AGENT_PRICE=0.02                      # Per-call fee in USDC

# === 0G Storage (Galileo testnet) ===
STORAGE_PRIVATE_KEY=0x...             # Wallet private key for 0G Storage uploads
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai

# === 0G Compute (same network) ===
COMPUTE_PRIVATE_KEY=0x...             # Can be same as STORAGE_PRIVATE_KEY

# === ENS (Sepolia testnet) ===
ENS_PRIVATE_KEY=0x...                 # Wallet controlling agentmcp.eth subnames
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# === Uniswap (Base mainnet for quotes) ===
BASE_RPC_URL=https://mainnet.base.org

# === Agent server ports ===
DEFI_ANALYST_PORT=3001
RESEARCH_PORT=3002
CODE_REVIEW_PORT=3003
